{
  "spec_version": "1.0",
  "metadata": {
    "id": "teamspeak3",
    "name": "TeamSpeak 3",
    "description": "TeamSpeak 3 server with ts3-manager web interface for easy administration.",
    "tagline": "Voice communication for gaming and business",
    "version": "1.0.1",
    "author": "",
    "developer": "TeamSpeak Systems GmbH",
    "category": "Communication",
    "license": "TeamSpeak License",
    "homepage": "https://hub.docker.com/_/teamspeak",
    "source": "",
    "created": "2026-03-23T00:00:00Z",
    "updated": "2026-03-24T00:00:00Z"
  },
  "visual": {
    "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/teamspeak.png",
    "thumbnail": "",
    "screenshots": [],
    "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/teamspeak.png"
  },
  "resources": {
    "youtube": "",
    "documentation": "https://www.ts3.app",
    "repository": "https://github.com/joni1802/ts3-manager",
    "issues": "",
    "support": ""
  },
  "technical": {
    "architectures": [
      "amd64"
    ],
    "platform": "linux",
    "main_service": "teamspeak-server",
    "default_port": "8080",
    "main_image": "teamspeak",
    "compose_file": "docker-compose.yml"
  },
  "deployment": {
    "environment_variables": [
      {
        "name": "TS3SERVER_LICENSE",
        "default": "accept",
        "description": "Must be set to 'accept' to agree to the TeamSpeak license",
        "required": true
      },
      {
        "name": "TZ",
        "default": "UTC",
        "description": "Timezone",
        "required": false
      },
      {
        "name": "TS3SERVER_IP",
        "default": "0.0.0.0",
        "description": "IP the server binds and advertises to clients. Set to 0.0.0.0 to listen on all interfaces. Change to your LAN or public IP if behind NAT.",
        "required": false
      },
      {
        "name": "TS3SERVER_QUERY_PROTOCOLS",
        "default": "raw,ssh",
        "description": "Comma-separated list of enabled ServerQuery protocols. 'raw' enables TCP (port 10011), 'ssh' enables SSH (port 10022).",
        "required": false
      }
    ],
    "volumes": [
      {
        "container": "/var/ts3server",
        "description": "TeamSpeak server data (databases, logs, files)"
      }
    ],
    "ports": [
      {
        "container": "9987",
        "host": "9987",
        "protocol": "udp",
        "description": "TeamSpeak voice"
      },
      {
        "container": "10011",
        "host": "10011",
        "protocol": "tcp",
        "description": "TeamSpeak ServerQuery raw TCP"
      },
      {
        "container": "10022",
        "host": "10022",
        "protocol": "tcp",
        "description": "TeamSpeak ServerQuery SSH"
      },
      {
        "container": "30033",
        "host": "30033",
        "protocol": "tcp",
        "description": "TeamSpeak file transfer"
      },
      {
        "container": "8080",
        "host": "8080",
        "protocol": "tcp",
        "description": "ts3-manager web UI"
      }
    ]
  },
  "ui": {
    "scheme": "http",
    "path": "",
    "tips": {
      "before_install": {
        "en_us": "After installation, open the ts3-manager web UI on port 8080 and connect to the TeamSpeak server using the hostname 'teamspeak-server', port 10011. The ServerQuery admin token is printed in the teamspeak-server container logs on first start.\n"
      }
    }
  },
  "compatibility": {
    "casaos": {
      "supported": true,
      "architectures": [
        "amd64"
      ],
      "port_map": "8080",
      "port": "8080"
    },
    "portainer": {
      "supported": true,
      "template_type": 2,
      "categories": [
        "Communication",
        "selfhosted"
      ],
      "administrator_only": false,
      "port": "8080"
    },
    "runtipi": {
      "supported": true,
      "tipi_version": 1,
      "supported_architectures": [
        "amd64"
      ],
      "port": "8080"
    },
    "dockge": {
      "supported": true,
      "file_based": true,
      "port": "8080"
    },
    "cosmos": {
      "supported": true,
      "servapp": true,
      "routes_required": true,
      "port": "8080"
    },
    "umbrel": {
      "supported": true,
      "manifest_version": 1,
      "port": "10028"
    }
  },
  "tags": [
    "teamspeak",
    "voice",
    "communication",
    "gaming",
    "selfhosted",
    "docker"
  ]
}
